{{/*
    This template generates a JSON file containing metadata about all regular pages in the site.
    Each page's metadata includes its title, URL, section, summary, content, and tags.
*/}}

{{- $pages := slice -}}
{{- range site.RegularPages -}}
  {{- $pages = $pages | append (dict
    "title"    .Title
    "url"      .RelPermalink
    "section"  .Section
    "summary"  (.Summary | plainify | truncate 200)
    "content"  (.Content | plainify | truncate 1000)
    "tags"     (.Params.tags | default slice)
  ) -}}
{{- end -}}
{{- $pages | jsonify -}}
